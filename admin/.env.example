# ---------------------------------------------------------------------------
# SAPIO Admin (Next.js) — environment template
# Copy to `.env.local` for local dev or `.env` on the server.
# Only NEXT_PUBLIC_* vars are exposed to the browser bundle.
# ---------------------------------------------------------------------------

# Base URL of the SAPIO Express backend, INCLUDING the /api prefix.
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Production example:
# NEXT_PUBLIC_API_URL=https://api.sapio.app/api

# Optional: Node env (Next.js defaults to "production" for `next start`).
NODE_ENV=production
