# ---------------------------------------------------------------------------
# SAPIO Backend — environment template
# Copy to `.env` and fill in real values. The server REFUSES to start if any
# required variable is missing (see src/config/index.ts).
# ---------------------------------------------------------------------------

# Server
PORT=4000
# Set to "production" on the server. Drives logging format + trust proxy.
NODE_ENV=development

# Supabase (Project Settings → API)
# URL looks like https://<project-ref>.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co
# "anon public" key (safe to ship to clients, RLS-enforced)
SUPABASE_ANON_KEY=your-anon-key
# "service_role" key — SERVER ONLY. Bypasses RLS. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS (comma-separated allowed origins)
# Production example:
# CORS_ORIGIN=https://admin.sapio.app,https://sapio.app,exp://u.expo.dev/<id>
CORS_ORIGIN=http://localhost:19006,exp://localhost:19000

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging (push notifications) — OPTIONAL
# If ALL THREE are set, push delivery is enabled. If any is missing, push is
# silently disabled and the app still works (inbox notifications remain).
# Get these from Firebase Console → Project Settings → Service Accounts →
# "Generate new private key". The private key contains \n — in .env keep them
# as literal backslash-n (the server converts them), or wrap the whole value in
# double quotes.
# ---------------------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
