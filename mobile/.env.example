# ---------------------------------------------------------------------------
# SAPIO Mobile (Expo) — environment template
# Copy to `.env` (or `.env.local`). ONLY variables prefixed with EXPO_PUBLIC_
# are embedded into the JS bundle at build time. Never put secrets here.
# ---------------------------------------------------------------------------

# Supabase (Project Settings → API)
# Same project as the backend. Use the "anon public" key (RLS-enforced).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (no /api suffix — the mobile appends paths itself).
# Local dev (Expo Go on same machine):
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
# Production (must be HTTPS and match CORS_ORIGIN on the backend):
# EXPO_PUBLIC_API_BASE_URL=https://api.sapio.app
# Physical device on same Wi-Fi (replace 192.168.x.x with your machine IP):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:4000

